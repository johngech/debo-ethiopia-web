{
  "name": "deboethiopia",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "bun x tsc -b && vite build",
    "lint:eslint": "eslint .",
    "preview": "vite preview",
    "prepare": "husky",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "check:dead": "bun run lint && bun x knip"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "knip": "^5.88.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@eslint/js": "^9.39.4",
    "@tanstack/eslint-plugin-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "daisyui": "^5.5.19",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,css}": [
      "biome check --write"
    ]
  }
}
